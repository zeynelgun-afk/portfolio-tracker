{
  "version": 1,
  "last_updated": "2026-02-18",
  "update_history": [],

  "entry_rules": {
    "max_positions": 3,
    "max_sector_weight_pct": 50,
    "min_score": 65,
    "avoid_earnings_within_days": 2,
    "min_avg_volume": 500000,
    "min_market_cap_M": 2000,
    "prefer_rsi_range": [30, 65],
    "require_above_50dma": true
  },

  "exit_rules": {
    "stop_loss_pct": -7.0,
    "trailing_stop_pct": -5.0,
    "profit_target_pct": 15.0,
    "max_hold_days": 30,
    "partial_exit_at_pct": 10.0,
    "partial_exit_size_pct": 50
  },

  "position_sizing": {
    "method": "equal_weight",
    "max_single_pct": 35,
    "scale_by_confidence": true,
    "confidence_multipliers": {
      "10": 1.3,
      "8": 1.1,
      "6": 1.0,
      "4": 0.7,
      "2": 0.5
    }
  },

  "market_regime_filter": {
    "enabled": true,
    "spy_above_200dma": true,
    "vix_max": 30,
    "breadth_min_pct": 40,
    "reduce_exposure_when": {
      "vix_above": 25,
      "breadth_below": 30,
      "action": "max_2_positions_and_tighter_stops"
    }
  },

  "sector_rotation": {
    "method": "ai_driven",
    "lookback_days": 30,
    "rebalance_frequency": "weekly",
    "max_sector_concentration": 2
  }
}
